{
  "name": "anya-ui",
  "version": "0.2.0",
  "description": "Minimal generative UI framework — agents produce markdown with affordances, framework renders to interactive DOM",
  "keywords": [
    "generative-ui",
    "agentic-ui",
    "llm",
    "ui-framework",
    "markdown"
  ],
  "license": "MIT",
  "author": "Anya UI Contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Constannnnnt/Anya.git",
    "directory": "packages/anya-ui"
  },
  "bugs": {
    "url": "https://github.com/Constannnnnt/Anya/issues"
  },
  "homepage": "https://github.com/Constannnnnt/Anya#readme",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/*.js",
    "dist/*.d.ts",
    "src/anya.css",
    "README.md",
    "LICENSE*"
  ],
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./protocol": {
      "import": {
        "types": "./dist/protocol.d.ts",
        "default": "./dist/protocol.js"
      }
    },
    "./measure": {
      "import": {
        "types": "./dist/measure.d.ts",
        "default": "./dist/measure.js"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "npx tsx build.ts && npx dts-bundle-generator -o dist/protocol.d.ts src/protocol.ts --project tsconfig.json --no-banner && npx dts-bundle-generator -o dist/index.d.ts src/index.ts --project tsconfig.json --no-banner && npx dts-bundle-generator -o dist/measure.d.ts src/measure.ts --project tsconfig.json --no-banner",
    "clean": "rm -rf dist",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm test"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "marked": "^15.0.0",
    "yaml": "^2.8.4"
  },
  "devDependencies": {
    "dts-bundle-generator": "^9.5.0",
    "esbuild": "^0.28.0",
    "jsdom": "^26.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
