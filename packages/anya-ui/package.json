{
  "name": "anya-ui",
  "version": "0.1.1",
  "description": "Agentic, generative user interface that adapts to user interactions and preferences",
  "keywords": [
    "generative-ui",
    "agentic-ui",
    "react",
    "typescript",
    "llm",
    "ui-framework"
  ],
  "license": "MIT",
  "author": "Anya UI Contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Constannnnnt/Anya.git",
    "directory": "packages/anya-ui"
  },
  "bugs": {
    "url": "https://github.com/Constannnnnt/Anya/issues"
  },
  "homepage": "https://github.com/Constannnnnt/Anya#readme",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.css",
    "dist-cjs/**/*.js",
    "dist-cjs/**/*.d.cts",
    "dist-cjs/package.json",
    "README.md",
    "LICENSE*"
  ],
  "main": "dist-cjs/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist-cjs/index.d.cts",
        "default": "./dist-cjs/index.js"
      },
      "default": "./dist/index.js"
    },
    "./core": {
      "import": {
        "types": "./dist/core/index.d.ts",
        "default": "./dist/core/index.js"
      },
      "require": {
        "types": "./dist-cjs/core/index.d.cts",
        "default": "./dist-cjs/core/index.js"
      },
      "default": "./dist/core/index.js"
    },
    "./react": {
      "import": {
        "types": "./dist/react/index.d.ts",
        "default": "./dist/react/index.js"
      },
      "require": {
        "types": "./dist-cjs/react/index.d.cts",
        "default": "./dist-cjs/react/index.js"
      },
      "default": "./dist/react/index.js"
    },
    "./react/*": {
      "import": "./dist/react/*",
      "require": "./dist-cjs/react/*",
      "default": "./dist/react/*"
    },
    "./adapters": {
      "import": {
        "types": "./dist/adapters/index.d.ts",
        "default": "./dist/adapters/index.js"
      },
      "require": {
        "types": "./dist-cjs/adapters/index.d.cts",
        "default": "./dist-cjs/adapters/index.js"
      },
      "default": "./dist/adapters/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "node scripts/clean-build.mjs && tsc -p tsconfig.json && tsc -p tsconfig.cjs.json && node scripts/minify.mjs && node scripts/postbuild.mjs",
    "prepublishOnly": "npm run build && npm test",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --pool=threads"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "lucide-react": "^0.577.0",
    "recharts": "^3.8.0",
    "valtio": "^2.3.1",
    "yaml": "^2.8.4",
    "zod": "^3.24.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
