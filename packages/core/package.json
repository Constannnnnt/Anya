{
  "name": "@anya-ui/core",
  "version": "0.1.0",
  "description": "Core logic for Anya UI — registry, memory, orchestrator, translator",
  "keywords": [
    "anya-ui",
    "agentic-ui",
    "typescript",
    "llm",
    "ui-framework"
  ],
  "license": "MIT",
  "author": "Anya UI Contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Constannnnnt/Anya.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/Constannnnnt/Anya/issues"
  },
  "homepage": "https://github.com/Constannnnnt/Anya#readme",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist-cjs/**/*.js",
    "dist-cjs/**/*.d.cts",
    "dist-cjs/package.json",
    "README.md",
    "LICENSE*"
  ],
  "main": "dist-cjs/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist-cjs/index.d.cts",
        "default": "./dist-cjs/index.js"
      },
      "default": "./dist/index.js"
    },
    "./experimental": {
      "import": {
        "types": "./dist/experimental.d.ts",
        "default": "./dist/experimental.js"
      },
      "require": {
        "types": "./dist-cjs/experimental.d.cts",
        "default": "./dist-cjs/experimental.js"
      },
      "default": "./dist/experimental.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "node scripts/clean-build.mjs && tsc && tsc -p tsconfig.cjs.json && node scripts/postbuild.mjs",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run --pool=threads",
    "bench": "npm run build && node bench/optimistic-update.bench.mjs",
    "bench:memory-store-read": "npm run build && node bench/memory-store-read.bench.mjs",
    "bench:memory-store-query": "npm run build && node bench/memory-store-query.bench.mjs",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "valtio": "^2.3.1",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
