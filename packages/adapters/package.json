{
  "name": "@anya-ui/adapters",
  "version": "0.1.0",
  "description": "Adapter utilities for Anya UI — session transports, session events, and artifact builders",
  "keywords": [
    "anya-ui",
    "adapters",
    "typescript",
    "agentic-ui",
    "transport"
  ],
  "license": "MIT",
  "author": "Anya UI Contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Constannnnnt/Anya.git",
    "directory": "packages/adapters"
  },
  "bugs": {
    "url": "https://github.com/Constannnnnt/Anya/issues"
  },
  "homepage": "https://github.com/Constannnnnt/Anya#readme",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist-cjs/**/*.js",
    "dist-cjs/**/*.d.cts",
    "dist-cjs/package.json",
    "README.md",
    "LICENSE*"
  ],
  "main": "dist-cjs/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist-cjs/index.d.cts",
        "default": "./dist-cjs/index.js"
      },
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "npm run build --workspace @anya-ui/core --if-present && node scripts/clean-build.mjs && tsc -p tsconfig.json && tsc -p tsconfig.cjs.json && node scripts/postbuild.mjs",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "npm run build --workspace @anya-ui/core --if-present && tsc -p tsconfig.json --noEmit",
    "test": "npm run build --workspace @anya-ui/core --if-present && vitest run --pool=threads",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "@anya-ui/core": "^0.1.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
